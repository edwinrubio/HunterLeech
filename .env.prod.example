# =============================================================================
# HunterLeech — Production Environment Variables (Dokploy)
# =============================================================================

# Neo4j password — CHANGE THIS to a strong random password
# Generate one: openssl rand -base64 32
NEO4J_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD

# Socrata API token (optional, raises rate limit from 1000 to 50000 req/hr)
# Register at: https://www.datos.gov.co/profile/edit/developer_settings
SOCRATA_APP_TOKEN=

# Privacy mode — always true in production (Ley 1581/2012)
PUBLIC_MODE=true

# ETL bootloader — set to 'true' on first deploy to load all data
# After first load completes, set back to 'false' to avoid re-running
# The load takes several hours (~10M records from datos.gov.co)
LOAD_DATA_BOOTLOADER=false

# Port — Dokploy/Traefik typically maps this automatically
PORT=80
