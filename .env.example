# Neo4j graph database password (required)
NEO4J_PASSWORD=changeme_in_production

# Socrata SODA App Token for datos.gov.co (optional but raises rate limit)
# Register at: https://data.cms.gov/developer
SOCRATA_APP_TOKEN=

# Privacy mode: true = hide protected personal data per Ley 1581/2012
PUBLIC_MODE=true

# ETL bootloader: set to 'true' to auto-load all data sources on first start
# Downloads ~10M records from datos.gov.co — takes several hours
LOAD_DATA_BOOTLOADER=false
